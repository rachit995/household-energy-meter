# Energy Monitor Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# SmartGridSoft Meter IDs (runtime)
# ===========================================
# These three are looked up once via `uv run python scripts/bootstrap_ids.py`
# and cached. The scraper skips login entirely and calls the vendor's
# undocumented JSON API directly.
SMARTGRID_SITE_ID=your_site_id
SMARTGRID_UNIT_ID=your_unit_id
SMARTGRID_METER_ID=your_meter_id

# ===========================================
# Bootstrap inputs (only needed for scripts/bootstrap_ids.py)
# ===========================================
# Required to resolve the three IDs above. Not read at runtime.
SMARTGRID_COMPANY=Your Society Name
SMARTGRID_TOWER=your_tower
SMARTGRID_FLAT=your_flat_number

# ===========================================
# Telegram Bot Notifications
# ===========================================
# Create a bot via @BotFather, get chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ===========================================
# Database (Neon Postgres)
# ===========================================
# Get this from https://neon.tech dashboard
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ===========================================
# Alerts (optional)
# ===========================================
MONTHLY_BUDGET=8000
SPIKE_THRESHOLD=1.5
