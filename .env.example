# Energy Monitor Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# Smartgridsoft Portal Credentials
# ===========================================
SMARTGRID_COMPANY=Your Company Name
SMARTGRID_USERNAME=your_unit_id
SMARTGRID_PASSWORD=your_password_here

# ===========================================
# Telegram Bot Notifications
# ===========================================
# Create a bot via @BotFather, get chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ===========================================
# Database (Neon Postgres)
# ===========================================
# Get this from https://neon.tech dashboard
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ===========================================
# Alerts (optional)
# ===========================================
LOW_BALANCE_THRESHOLD=800
MONTHLY_BUDGET=8000
SPIKE_THRESHOLD=1.5
